@page "/forgot-password"
@rendermode InteractiveServer
@layout AuthLayout
@inject ApiService Api
@inject IJSRuntime JS
@inject IConfiguration Config

<PageTitle>Forgot Password - Shaiya</PageTitle>

<h4 class="sh-auth-title">Reset Password</h4>

<Alert Message="@_error" Type="error" OnDismiss="() => _error = null" />
<Alert Message="@_success" Type="success" OnDismiss="() => _success = null" />

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <div class="mb-3">
        <label class="form-label">Username</label>
        <InputText @bind-Value="_model.Username" class="form-control sh-input" placeholder="Your username" />
    </div>
    <div class="mb-3">
        <label class="form-label">Security Answer</label>
        <InputText @bind-Value="_model.SecurityAnswer" class="form-control sh-input" placeholder="Your security question answer" />
    </div>
    <div class="mb-3">
        <div id="cf-turnstile-forgot" class="cf-turnstile" data-sitekey="@Config["Turnstile:SiteKey"]" data-callback="onTurnstileForgot"></div>
    </div>
    <div class="d-grid">
        <button type="submit" class="btn sh-btn-gold" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Send Reset Link
        </button>
    </div>
</EditForm>

<p class="text-center mt-3">
    <a href="/login" class="sh-auth-link">Back to Login</a>
</p>

@code {
    private readonly ForgotModel _model = new();
    private string? _error;
    private string? _success;
    private bool _loading;

    private async Task HandleSubmit()
    {
        _loading = true;
        var token = await JS.InvokeAsync<string?>("getTurnstileToken", "forgot") ?? string.Empty;
        var (_, message) = await Api.ForgotPasswordAsync(_model.Username, _model.SecurityAnswer, token);
        _success = message;
        await JS.InvokeVoidAsync("resetTurnstile", "forgot");
        _loading = false;
    }

    private class ForgotModel
    {
        public string Username { get; set; } = string.Empty;
        public string SecurityAnswer { get; set; } = string.Empty;
    }
}
