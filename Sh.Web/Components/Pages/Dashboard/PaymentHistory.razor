@page "/dashboard/payments"
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@inject ApiService Api

<PageTitle>Payment History - Shaiya</PageTitle>
<div class="container py-4">
    <h1 class="sh-page-title">Payment History</h1>
    @if (_payments != null && _payments.Count > 0)
    {
        <div class="sh-table-container">
            <table class="table sh-table">
                <thead><tr><th>Date</th><th>Provider</th><th>Amount</th><th>Points</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var p in _payments)
                    {
                        <tr>
                            <td>@p.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>@p.Provider</td>
                            <td>@p.Amount @p.Currency</td>
                            <td class="sh-gold">@p.PointsAwarded</td>
                            <td><span class="badge @(p.Status=="completed"?"bg-success":"bg-secondary")">@p.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <p class="text-muted">No payment history.</p> }
</div>
@code {
    private List<PaymentDto>? _payments;
    protected override async Task OnInitializedAsync() => _payments = await Api.GetPaymentHistoryAsync();
}
