@page "/dashboard"
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@inject ApiService Api
@inject AuthStateProvider Auth

<PageTitle>Dashboard - Shaiya</PageTitle>

<div class="container py-4">
    @if (_loading) { <div class="sh-loading">Loading...</div> }
    else if (_data != null)
    {
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="sh-stat-card">
                    <div class="sh-stat-value sh-gold">@_data.User.Point</div>
                    <div class="sh-stat-label">Shaiya Points</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="sh-stat-card">
                    <div class="sh-stat-value sh-gold">@_data.User.Vp</div>
                    <div class="sh-stat-label">Vote Points</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="sh-stat-card">
                    <div class="sh-stat-value">@_data.Characters.Count</div>
                    <div class="sh-stat-label">Characters</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="sh-stat-card">
                    <div class="sh-stat-value">@_data.User.JoinDate.ToString("yyyy")</div>
                    <div class="sh-stat-label">Member Since</div>
                </div>
            </div>
        </div>
        <h4 class="sh-section-title">Your Characters</h4>
        <div class="row g-3">
            @foreach (var c in _data.Characters)
            {
                <div class="col-md-4">
                    <div class="sh-char-card">
                        <div class="sh-char-name sh-gold">@c.CharName</div>
                        <div class="text-muted small">Lv.@c.Level | @GetJobName(c.Job)</div>
                        <div class="text-muted small">Kills: @c.K1</div>
                        @if (c.LoginStatus) { <span class="badge bg-success mt-1">Online</span> }
                    </div>
                </div>
            }
        </div>
        <div class="row g-3 mt-4">
            <div class="col"><a href="/dashboard/shop" class="btn sh-btn-gold w-100">Shop</a></div>
            <div class="col"><a href="/dashboard/vote" class="btn sh-btn-outline w-100">Vote</a></div>
            <div class="col"><a href="/dashboard/roulette" class="btn sh-btn-outline w-100">Roulette</a></div>
            <div class="col"><a href="/dashboard/redeem" class="btn sh-btn-outline w-100">Redeem Code</a></div>
            <div class="col"><a href="/dashboard/battle-pass" class="btn sh-btn-outline w-100">Battle Pass</a></div>
        </div>
    }
</div>

@code {
    private DashboardDto? _data;
    private bool _loading = true;
    protected override async Task OnInitializedAsync() { _data = await Api.GetDashboardAsync(); _loading = false; }
    private static string GetJobName(short j) => j switch { 1=>"Fighter",2=>"Defender",3=>"Ranger",4=>"Archer",5=>"Mage",6=>"Priest",_=>$"Job {j}" };
}
