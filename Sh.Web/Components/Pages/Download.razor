@page "/download"
@layout MainLayout

<PageTitle>Download - Shaiya</PageTitle>

<div class="container py-5">
    <h1 class="sh-page-title">Download</h1>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="sh-card text-center">
                <h4 class="sh-card-title">Full Client</h4>
                <p class="text-muted">Download the complete game client. Recommended for new players.</p>
                <p class="sh-gold fw-bold">~4 GB</p>
                <a href="#" class="btn sh-btn-gold w-100">Download Full Client</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="sh-card text-center">
                <h4 class="sh-card-title">Patch Only</h4>
                <p class="text-muted">Already have the base client? Download the patch files only.</p>
                <p class="sh-gold fw-bold">~500 MB</p>
                <a href="#" class="btn sh-btn-outline w-100">Download Patch</a>
            </div>
        </div>
        <div class="col-12">
            <div class="sh-card">
                <h4 class="sh-card-title">Installation Guide</h4>
                <ol>
                    <li>Download the full client and extract it</li>
                    <li>Run the launcher as Administrator</li>
                    <li>Allow the launcher to update your game files</li>
                    <li>Create an account or log in</li>
                    <li>Enjoy the game!</li>
                </ol>
            </div>
        </div>
    </div>
</div>
