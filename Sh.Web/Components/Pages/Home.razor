@page "/"
@rendermode InteractiveServer
@layout MainLayout
@inject ApiService Api

<PageTitle>Shaiya - Home</PageTitle>

<div class="sh-hero">
    <div class="container">
        <div class="sh-hero-content text-center">
            <h1 class="sh-hero-title">Welcome to <span class="sh-gold">Shaiya</span></h1>
            <p class="sh-hero-subtitle">Experience the ultimate MMORPG adventure</p>
            <div class="sh-hero-stats">
                @if (_data?.ServerStatus != null)
                {
                    <div class="sh-stat-badge @(_data.ServerStatus.Online ? "online" : "offline")">
                        <span class="sh-stat-dot"></span>
                        @(_data.ServerStatus.Online ? "Server Online" : "Server Offline")
                    </div>
                    @if (_data.ServerStatus.Online)
                    {
                        <div class="sh-stat-badge">
                            👥 @_data.ServerStatus.Players Players Online
                        </div>
                    }
                }
            </div>
            <div class="mt-4">
                <a href="/download" class="btn sh-btn-gold btn-lg me-3">Download Now</a>
                <a href="/register" class="btn sh-btn-outline btn-lg">Create Account</a>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="sh-section-title">Latest News</h2>
            @if (_loading)
            {
                <div class="sh-loading">Loading...</div>
            }
            else if (_data?.LatestNews.Count == 0)
            {
                <p class="text-muted">No news available.</p>
            }
            else
            {
                @foreach (var news in _data?.LatestNews ?? [])
                {
                    <div class="sh-news-card mb-3">
                        <div class="sh-news-category">@news.Category</div>
                        <h4 class="sh-news-title">@news.Title</h4>
                        <p class="sh-news-excerpt">@(news.Content.Length > 200 ? news.Content[..200] + "..." : news.Content)</p>
                        <small class="text-muted">@news.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                }
                <a href="/news" class="btn sh-btn-outline mt-2">View All News</a>
            }
        </div>
        <div class="col-lg-4">
            <h2 class="sh-section-title">Top PvP</h2>
            <div class="sh-pvp-card">
                @if (_data?.PvpRanking.Count > 0)
                {
                    <ol class="sh-pvp-list">
                        @foreach (var c in _data.PvpRanking.Take(5))
                        {
                            <li class="sh-pvp-item">
                                <span class="sh-pvp-name">@c.CharName</span>
                                <span class="sh-pvp-kills sh-gold">@c.K1 kills</span>
                            </li>
                        }
                    </ol>
                    <a href="/pvp-ranking" class="btn sh-btn-outline btn-sm w-100 mt-2">Full Ranking</a>
                }
                else
                {
                    <p class="text-muted text-center py-3">No data available.</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private HomeDto? _data;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _data = await Api.GetHomeAsync();
        _loading = false;
    }
}
