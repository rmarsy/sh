@page "/admin"
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav
@inject AuthStateProvider Auth

<PageTitle>Admin - Shaiya</PageTitle>
<div class="container py-4">
    <h1 class="sh-page-title">Admin Panel</h1>
    <div class="row g-3">
        <div class="col-md-3"><a href="/admin/users" class="btn sh-btn-gold w-100 py-3">Manage Users</a></div>
        <div class="col-md-3"><a href="/admin/news" class="btn sh-btn-outline w-100 py-3">Patch Notes</a></div>
        <div class="col-md-3"><a href="/admin/redeem-codes" class="btn sh-btn-outline w-100 py-3">Redeem Codes</a></div>
        <div class="col-md-3"><a href="/admin/shop" class="btn sh-btn-outline w-100 py-3">Shop Items</a></div>
        <div class="col-md-3"><a href="/admin/settings" class="btn sh-btn-outline w-100 py-3">Site Settings</a></div>
    </div>
</div>
@code {
    protected override void OnInitialized() { if (!Auth.IsAdmin) Nav.NavigateTo("/dashboard"); }
}
