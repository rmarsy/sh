# Copy this file to .env and fill in the values for production.
# The .env file is automatically loaded by Docker Compose.

# ── SQL Server ────────────────────────────────────────────────────────────────
MSSQL_SA_PASSWORD=Shaiya123!Strong   # SA (system admin) password — must meet SQL Server complexity rules
MSSQL_USER=Shaiya                    # Application DB user
MSSQL_PASSWORD=Shaiya123             # Application DB user password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_KEY=CHANGE_ME_TO_A_SECURE_KEY_AT_LEAST_32_CHARS_LONG

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=YOUR_CLOUDFLARE_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_CLOUDFLARE_TURNSTILE_SECRET_KEY
TURNSTILE_ENABLED=true

# ── Launcher API key ──────────────────────────────────────────────────────────
API_KEY=CHANGE_ME_TO_A_SECURE_API_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
# Public URL of Sh.Web as seen by end-users' browsers.
WEB_ORIGIN=http://localhost:5001
